  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "bullmq": "^5.73.5",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "pg": "^8.20.0",
    "resend": "^6.11.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  }
}
